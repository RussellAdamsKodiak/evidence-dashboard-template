# Elasticsearch connection — one of API key or basic auth
ES_URL=https://your-cluster.es.us-west-2.aws.found.io
ES_API_KEY=your_base64_api_key_here
# ES_USERNAME=monitoring
# ES_PASSWORD=your_password_here

# Index and field names
# Defaults shown match Kodiak's debug_log_index schema:
ES_INDEX=debug_log_index-*
ES_TIMESTAMP_FIELD=@timestamp
ES_SEVERITY_FIELD=severity
ES_TRUCK_FIELD=truck_name
ES_TOP_N=15
